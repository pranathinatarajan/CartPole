<?xml version="1.0"?>
<robot name="cartpole">

  <link name="world"/>

  <joint name="world_to_rail" type="fixed">
    <parent link="world"/>
    <child link="rail"/>
    <origin xyz="0 0 0.5"/>
  </joint>

  <link name="rail">
    <visual>
      <geometry>
        <box size="3.0 0.05 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0"
               iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <joint name="rail_to_cart" type="prismatic">
    <parent link="rail"/>
    <child link="cart"/>
    <axis xyz="1 0 0"/>
    <origin xyz="0 0 0"/>
    <limit effort="1000" lower="-1.5" upper="1.5" velocity="5"/>
  </joint>

  <link name="cart">
    <visual>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="cart_to_pole" type="continuous">
    <parent link="cart"/>
    <child link="pole"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <link name="pole">
    <visual>
      <origin xyz="0 0 0.5"/>
      <geometry>
        <cylinder radius="0.01" length="1.0"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0.5"/>
      <mass value="0.1"/>
      <inertia ixx="0.0083" ixy="0.0" ixz="0.0"
               iyy="0.0083" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

</robot>